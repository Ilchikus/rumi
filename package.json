{
  "name": "rumi-new",
  "version": "0.0.0",
  "description": "File-first, open-source, self-hosted Markdown editor",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ilchikus/rumi.git"
  },
  "homepage": "https://rumi.md",
  "bugs": {
    "url": "https://github.com/Ilchikus/rumi/issues"
  },
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "build": "corepack pnpm --filter @rumi/web build && corepack pnpm --filter @rumi-md/server build:bundle",
    "check": "corepack pnpm typecheck && corepack pnpm test && corepack pnpm build",
    "check:server-package": "corepack pnpm --filter @rumi-md/server release:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:server": "tsx apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "cli": "tsx apps/cli/src/index.ts",
    "start": "tsx apps/server/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "fastify": "^5.1.0",
    "pino-pretty": "^13.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "yaml": "^2.6.1"
  }
}
